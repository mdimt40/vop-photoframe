<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ভাঙ্গা টু পটুয়াখালী ৬ লেন — Voice of Patuakhali</title>
<link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;500;600;700&family=Barlow+Condensed:wght@700;900&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --red: #C8102E;
  --red-dark: #9B0B22;
  --white: #ffffff;
  --cream: #FFF8F5;
  --dark: #1f1f1f;
  --bg: #ffffff;
  --surface: #ffffff;
  --surface-soft: #faf7f6;
  --border: #eadfdd;
  --text: #1f1f1f;
  --muted: #6f6f6f;
}

body {
  background: linear-gradient(180deg, #ffffff 0%, #fffaf9 100%);
  font-family: 'Hind Siliguri', sans-serif;
  color: var(--text);
  min-height: 100vh;
}

/* ── HEADER ─────────────────────────────────────────────────── */
header {
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--border);
  padding: 0;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 20px rgba(200,16,46,0.08);
}
.header-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 12px 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}
.logo-wrap { display: flex; align-items: center; gap: 12px; }
.logo-mark {
  width: 44px; height: 44px;
  background: linear-gradient(135deg, #fff 0%, #fff4f5 100%);
  border-radius: 8px;
  display: block;
  flex-shrink: 0;
  border: 1px solid var(--border);
  object-fit: contain;
  padding: 0;
}
.logo-text {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 20px; font-weight: 900;
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--text); line-height: 1.1;
}
.logo-text small {
  display: block; font-size: 10px;
  letter-spacing: 3px; opacity: 0.85; font-weight: 700;
}
.header-tag {
  background: #fff5f7;
  border: 1px solid #f0c8cf;
  color: var(--red);
  font-size: 12px; font-weight: 700;
  letter-spacing: 1px;
  padding: 6px 14px;
  border-radius: 4px;
  font-family: 'Barlow Condensed', sans-serif;
  text-transform: uppercase;
  white-space: nowrap;
}

/* ── HERO ────────────────────────────────────────────────────── */
.hero {
  background: linear-gradient(135deg, #fff 0%, #fff7f8 100%);
  border-bottom: 1px solid var(--border);
  padding: 56px 24px 48px;
  text-align: center;
}
.hero-badge {
  display: inline-block;
  background: #fff5f7;
  border: 1px solid #f0c8cf;
  color: var(--red);
  font-size: 14px; font-weight: 700;
  letter-spacing: 1px;
  padding: 6px 20px;
  border-radius: 30px;
  margin-bottom: 20px;
}
.hero h1 {
  font-size: clamp(22px, 5vw, 40px);
  font-weight: 900;
  line-height: 1.4;
  color: var(--text);
  max-width: 800px;
  margin: 0 auto 20px;
}
.hero h1 .red { color: var(--red); }
.hero-desc {
  font-size: 16px;
  color: var(--muted);
  line-height: 1.9;
  max-width: 680px;
  margin: 0 auto 28px;
}
.hero-points {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12px;
  max-width: 700px;
  margin: 0 auto;
}
.hero-point {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 12px 20px;
  font-size: 14px;
  font-weight: 600;
  color: var(--text);
  display: flex; align-items: center; gap: 8px;
  box-shadow: 0 4px 18px rgba(31,31,31,0.04);
}
.hero-point .dot {
  width: 8px; height: 8px;
  background: var(--red);
  border-radius: 50%;
  flex-shrink: 0;
}

/* ── MAIN LAYOUT ─────────────────────────────────────────────── */
.page {
  max-width: 900px;
  margin: 0 auto;
  padding: 48px 20px 60px;
  display: flex;
  flex-direction: column;
  gap: 48px;
}

/* ── SAMPLE PREVIEW ──────────────────────────────────────────── */
.sample-preview {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 24px;
  box-shadow: 0 8px 28px rgba(31,31,31,0.05);
}
.sample-preview img {
  display: block;
  width: 100%;
  height: auto;
  border-radius: 10px;
  border: 1px solid var(--border);
  box-shadow: 0 10px 28px rgba(31,31,31,0.08);
}

/* ── HOW-TO SECTION ──────────────────────────────────────────── */
.howto-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 32px 28px;
  box-shadow: 0 8px 28px rgba(31,31,31,0.05);
}
.section-title {
  font-size: 18px; font-weight: 900;
  color: var(--red);
  letter-spacing: 1px;
  margin-bottom: 24px;
  display: flex; align-items: center; gap: 10px;
}
.section-title::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}
.steps-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 16px;
}
.step-card {
  background: var(--surface-soft);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 20px 16px;
  display: flex; flex-direction: column; gap: 10px;
}
.step-num {
  width: 32px; height: 32px;
  background: var(--red);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 16px; font-weight: 900;
  color: #fff;
}
.step-card p { font-size: 14px; color: var(--muted); line-height: 1.7; }

/* ── POSTER TOOL ─────────────────────────────────────────────── */
.tool-wrap {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  overflow: hidden;
  box-shadow: 0 10px 30px rgba(31,31,31,0.06);
}
.tool-header {
  background: linear-gradient(135deg, #fff 0%, #fff5f7 100%);
  border-bottom: 1px solid var(--border);
  padding: 14px 24px;
  display: flex; align-items: center; gap: 10px;
  font-size: 16px; font-weight: 900; letter-spacing: 1px;
}
.tool-body { padding: 28px 24px; display: flex; flex-direction: column; gap: 20px; }

/* Upload */
.upload-zone {
  border: 2px dashed #e4c9cf;
  border-radius: 10px;
  padding: 40px 20px;
  text-align: center;
  cursor: pointer;
  position: relative;
  background: #fff;
  transition: background 0.2s, border-color 0.2s;
}
.upload-zone:hover, .upload-zone.drag-over { background: #fff7f8; border-color: var(--red); }
.upload-zone input { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
.upload-zone .uicon { font-size: 44px; margin-bottom: 12px; }
.upload-zone h3 { font-size: 20px; font-weight: 900; color: var(--text); margin-bottom: 6px; }
.upload-zone p { font-size: 13px; color: var(--muted); }

/* Crop canvas */
.crop-stage { display: none; flex-direction: column; gap: 14px; align-items: center; }
.crop-stage.visible { display: flex; }
.crop-lbl { font-size: 12px; letter-spacing: 2px; text-transform: uppercase; color: var(--red); font-weight: 700; align-self: flex-start; font-family: 'Barlow Condensed', sans-serif; }
#cropCanvas { border: 2px solid var(--red); border-radius: 8px; display: block; max-width: 100%; touch-action: none; cursor: crosshair; }
.crop-hint { font-size: 12px; color: var(--muted); letter-spacing: 1px; text-align: center; }
.crop-hint b { color: var(--red); }

/* Preview */
.preview-stage { display: none; flex-direction: column; gap: 14px; align-items: center; }
.preview-stage.visible { display: flex; }
#outputCanvas { max-width: 100%; border-radius: 8px; border: 3px solid var(--red); box-shadow: 0 8px 40px rgba(200,16,46,0.3); }

/* Buttons */
.btn-row { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; }
.btn {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 15px; font-weight: 900;
  letter-spacing: 2px; text-transform: uppercase;
  padding: 12px 26px; border-radius: 6px;
  border: none; cursor: pointer; transition: all 0.15s;
  white-space: nowrap;
}
.btn-red  { background: var(--red); color: #fff; }
.btn-red:hover { background: var(--red-dark); }
.btn-ghost { background: #fff; color: var(--red); border: 2px solid var(--red); }
.btn-ghost:hover { background: #fff5f7; }
.btn-dl {
  font-size: 18px; padding: 16px 40px;
  background: var(--red); color: #fff;
  box-shadow: 0 4px 24px rgba(200,16,46,0.45);
}
.btn-dl:hover { background: var(--red-dark); transform: translateY(-2px); }

/* Step dots */
.step-dots { display: flex; gap: 8px; align-items: center; font-family: 'Barlow Condensed', sans-serif; font-size: 12px; letter-spacing: 2px; color: #444; }
.sdot { width: 22px; height: 22px; border-radius: 50%; border: 1px solid var(--red); color: var(--red); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 900; }
.sdot.on { background: var(--red); color: #fff; }

/* ── HASHTAGS ─────────────────────────────────────────────────── */
.hashtag-section {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 28px;
  box-shadow: 0 8px 28px rgba(31,31,31,0.05);
}
.tags-wrap { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 16px; }
.tag {
  background: #fff5f7;
  border: 1px solid #f0c8cf;
  color: var(--red);
  font-size: 13px; font-weight: 700;
  padding: 7px 14px;
  border-radius: 6px;
  cursor: pointer;
  transition: background 0.15s;
  font-family: 'Barlow Condensed', sans-serif;
  letter-spacing: 0.5px;
}
.tag:hover { background: #ffe9ed; }
.copy-notice { font-size: 12px; color: var(--muted); margin-top: 8px; }
.copy-notice span { color: var(--red); }

/* ── FOOTER ──────────────────────────────────────────────────── */
footer {
  background: #fff;
  border-top: 1px solid var(--border);
  padding: 24px;
  text-align: center;
}
footer p { font-size: 13px; color: var(--muted); }
footer p span { color: var(--red); font-weight: 700; }

/* ── RESPONSIVE ──────────────────────────────────────────────── */
@media (max-width: 600px) {
  .hero { padding: 36px 16px 32px; }
  .tool-body { padding: 20px 14px; }
  .howto-card { padding: 24px 16px; }
  .hashtag-section { padding: 20px 16px; }
}
</style>
</head>
