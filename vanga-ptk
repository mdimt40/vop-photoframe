<script>
// ── Config ────────────────────────────────────────────────────────────
const CANVAS_W = 3264, CANVAS_H = 3264;
const SLOT     = { x: 361, y: 1463, w: 1486, h: 1615 };
const RATIO    = SLOT.w / SLOT.h; // 1486/1615 ≈ 0.9202
const MIN_BOX  = 50;
const HIT_R    = 20;

// ── State ─────────────────────────────────────────────────────────────
let srcImg     = null;
let overlayImg = null;
let box        = { x:0, y:0, w:0, h:0 };
let cvW = 0, cvH = 0;
let drag = null, startPtr = null, startBox = null;

// Load campaign.png overlay
(function(){
  const img = new Image();
  img.onload = () => overlayImg = img;
  img.src    = 'campaign.png';
})();

// ── Upload ────────────────────────────────────────────────────────────
document.getElementById('fileInput').addEventListener('change', e => {
  if (e.target.files[0]) readFile(e.target.files[0]);
});
const uploadZone = document.getElementById('uploadZone');
uploadZone.addEventListener('dragover',  e => { e.preventDefault(); uploadZone.classList.add('drag-over'); });
uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over'));
uploadZone.addEventListener('drop', e => {
  e.preventDefault(); uploadZone.classList.remove('drag-over');
  if (e.dataTransfer.files[0]) readFile(e.dataTransfer.files[0]);
});

function readFile(f) {
  if (!f.type.startsWith('image/')) return;
  const reader = new FileReader();
  reader.onload = ev => {
    const img = new Image();
    img.onload = () => {
      srcImg = img;
      uploadZone.style.display = 'none';
      showEl('cropStage');
      setStep(2);
      requestAnimationFrame(initCropCanvas);
    };
    img.src = ev.target.result;
  };
  reader.readAsDataURL(f);
}

// ── Crop canvas ───────────────────────────────────────────────────────
const cc  = document.getElementById('cropCanvas');
const ctx = cc.getContext('2d');

function initCropCanvas() {
  // Canvas display size: fit image inside available width, max 520px tall
  const maxW = Math.min(cc.parentElement.clientWidth - 4, 820);
  const maxH = 520;
  const iRatio = srcImg.naturalWidth / srcImg.naturalHeight;

  let cw, ch;
  if (iRatio >= maxW / maxH) { cw = maxW;           ch = Math.round(cw / iRatio); }
  else                        { ch = maxH;           cw = Math.round(ch * iRatio); }

  // Canvas internal resolution = display size (1:1 CSS px mapping)
  cc.width  = cw; cc.height = ch;
  cc.style.width  = cw + 'px';
  cc.style.height = ch + 'px';
  cvW = cw; cvH = ch;

  resetCrop();
}

function resetCrop() {
  // Largest RATIO-locked box centred in canvas
  let w = cvW, h = w / RATIO;
  if (h > cvH) { h = cvH; w = h * RATIO; }
  box = { x: (cvW - w) / 2, y: (cvH - h) / 2, w, h };
  render();
}

function render() {
  ctx.clearRect(0, 0, cvW, cvH);
  // Image — drawn to fill the canvas exactly (canvas already matches image ratio)
  ctx.drawImage(srcImg, 0, 0, cvW, cvH);

  // Dim outside crop
  ctx.fillStyle = 'rgba(0,0,0,0.6)';
  ctx.fillRect(0,       0,      cvW,       box.y);
  ctx.fillRect(0,       box.y + box.h, cvW, cvH - box.y - box.h);
  ctx.fillRect(0,       box.y, box.x,    box.h);
  ctx.fillRect(box.x + box.w, box.y, cvW - box.x - box.w, box.h);

  // Crop box border
  ctx.strokeStyle = '#fff'; ctx.lineWidth = 2;
  ctx.strokeRect(box.x, box.y, box.w, box.h);

  // Rule-of-thirds
  ctx.strokeStyle = 'rgba(255,255,255,0.22)'; ctx.lineWidth = 1;
  for (let i = 1; i < 3; i++) {
    const lx = box.x + box.w / 3 * i;
    const ly = box.y + box.h / 3 * i;
    ctx.beginPath(); ctx.moveTo(lx, box.y);      ctx.lineTo(lx, box.y + box.h); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(box.x, ly);       ctx.lineTo(box.x + box.w, ly); ctx.stroke();
  }

  // Corner handles
  const corners = [
    [box.x,        box.y       ],
    [box.x + box.w, box.y      ],
    [box.x,        box.y + box.h],
    [box.x + box.w, box.y + box.h],
  ];
  corners.forEach(([cx2, cy2]) => {
    ctx.beginPath(); ctx.arc(cx2, cy2, 8, 0, Math.PI * 2);
    ctx.fillStyle = '#C8102E'; ctx.fill();
    ctx.strokeStyle = '#fff'; ctx.lineWidth = 2; ctx.stroke();
  });

  // Ratio pill
  ctx.fillStyle = 'rgba(200,16,46,0.88)';
  ctx.beginPath();
  roundRect(ctx, box.x + box.w - 138, box.y + box.h - 26, 132, 20, 4);
  ctx.fill();
  ctx.fillStyle = '#fff';
  ctx.font = 'bold 11px Barlow Condensed, sans-serif';
  ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
  ctx.fillText('অনুপাত লক ✓', box.x + box.w - 72, box.y + box.h - 16);
}

function roundRect(c, x, y, w, h, r) {
  c.moveTo(x+r, y); c.lineTo(x+w-r, y);
  c.quadraticCurveTo(x+w,y,x+w,y+r);
  c.lineTo(x+w,y+h-r); c.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
  c.lineTo(x+r,y+h); c.quadraticCurveTo(x,y+h,x,y+h-r);
  c.lineTo(x,y+r); c.quadraticCurveTo(x,y,x+r,y);
  c.closePath();
}

// ── Pointer events ────────────────────────────────────────────────────
cc.addEventListener('mousedown',  onDown);
cc.addEventListener('touchstart', onDown, { passive: false });
window.addEventListener('mousemove',  onMove);
window.addEventListener('touchmove',  onMove, { passive: false });
window.addEventListener('mouseup',   () => { drag = null; cc.style.cursor = 'crosshair'; });
window.addEventListener('touchend',  () => { drag = null; });

function evPos(e) {
  const r   = cc.getBoundingClientRect();
  const src = e.touches ? e.touches[0] : e;
  // No DPR scaling needed — canvas px == CSS px
  return { x: src.clientX - r.left, y: src.clientY - r.top };
}

function hitCorner(p) {
  const pts = [
    { id:'tl', x: box.x,        y: box.y        },
    { id:'tr', x: box.x+box.w,  y: box.y        },
    { id:'bl', x: box.x,        y: box.y+box.h  },
    { id:'br', x: box.x+box.w,  y: box.y+box.h  },
  ];
  return pts.find(pt => Math.abs(p.x-pt.x) < HIT_R && Math.abs(p.y-pt.y) < HIT_R) || null;
}

function onDown(e) {
  e.preventDefault();
  const p = evPos(e);
  startPtr = p; startBox = { ...box };
  const c = hitCorner(p);
  if (c) {
    drag = { type:'resize', corner: c.id };
    cc.style.cursor = { tl:'nw-resize', tr:'ne-resize', bl:'sw-resize', br:'se-resize' }[c.id];
  } else if (p.x > box.x && p.x < box.x+box.w && p.y > box.y && p.y < box.y+box.h) {
    drag = { type:'move' };
    cc.style.cursor = 'grab';
  }
}

function onMove(e) {
  if (!drag) return;
  e.preventDefault();
  const p  = evPos(e);
  const dx = p.x - startPtr.x;
  const dy = p.y - startPtr.y;

  if (drag.type === 'move') {
    box.x = clamp(startBox.x + dx, 0, cvW - box.w);
    box.y = clamp(startBox.y + dy, 0, cvH - box.h);
  } else {
    resize(drag.corner, dx, dy);
  }
  render();
}

function resize(corner, dx, dy) {
  let { x, y, w, h } = startBox;

  if (corner === 'br') {
    w = clamp(w + dx, MIN_BOX, cvW - x);
    h = w / RATIO;
    if (y + h > cvH) { h = cvH - y; w = h * RATIO; }
  } else if (corner === 'bl') {
    w = clamp(w - dx, MIN_BOX, x + w);
    h = w / RATIO;
    x = startBox.x + startBox.w - w;
    if (x < 0) { x = 0; w = startBox.x + startBox.w; h = w / RATIO; }
    if (y + h > cvH) { h = cvH - y; w = h * RATIO; x = startBox.x + startBox.w - w; }
  } else if (corner === 'tr') {
    w = clamp(w + dx, MIN_BOX, cvW - x);
    h = w / RATIO;
    y = startBox.y + startBox.h - h;
    if (y < 0) { y = 0; h = startBox.y + startBox.h; w = h * RATIO; }
  } else if (corner === 'tl') {
    w = clamp(w - dx, MIN_BOX, x + w);
    h = w / RATIO;
    x = startBox.x + startBox.w - w;
    y = startBox.y + startBox.h - h;
    if (x < 0) { x = 0; w = startBox.x + startBox.w; h = w / RATIO; y = startBox.y + startBox.h - h; }
    if (y < 0) { y = 0; h = startBox.y + startBox.h; w = h * RATIO; x = startBox.x + startBox.w - w; }
  }
  box = { x, y, w, h };
}

function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

// ── Apply crop & render poster ─────────────────────────────────────────
function applyCrop() {
  // box is already in canvas px == display px (no DPR scaling needed)
  // Map to natural image coords
  const scX = srcImg.naturalWidth  / cvW;
  const scY = srcImg.naturalHeight / cvH;
  const sx = box.x * scX, sy = box.y * scY;
  const sw = box.w * scX, sh = box.h * scY;

  const out = document.getElementById('outputCanvas');
  out.width = CANVAS_W; out.height = CANVAS_H;
  const oc = out.getContext('2d');

  oc.fillStyle = '#FFFFFF';
  oc.fillRect(0, 0, CANVAS_W, CANVAS_H);

  // 1. User photo — bottom layer
  oc.drawImage(srcImg, sx, sy, sw, sh, SLOT.x, SLOT.y, SLOT.w, SLOT.h);

  // 2. campaign.png — top layer
  if (overlayImg) {
    oc.drawImage(overlayImg, 0, 0, CANVAS_W, CANVAS_H);
  } else {
    oc.fillStyle = 'rgba(200,16,46,0.18)';
    oc.fillRect(0, 0, CANVAS_W, CANVAS_H);
    oc.fillStyle = '#C8102E';
    oc.font = 'bold 52px sans-serif';
    oc.textAlign = 'center'; oc.textBaseline = 'middle';
    oc.fillText('campaign.png এই HTML ফাইলের পাশে রাখুন', CANVAS_W/2, CANVAS_H/2);
  }

  hideEl('cropStage');
  showEl('previewStage');
  setStep(3);
  out.scrollIntoView({ behavior:'smooth', block:'nearest' });
}

function downloadPoster() {
  const a = document.createElement('a');
  a.download = 'bhanga-patuakhali-6lane-poster.png';
  a.href = document.getElementById('outputCanvas').toDataURL('image/png');
  a.click();
}

// ── Nav ────────────────────────────────────────────────────────────────
function goBack()    { hideEl('previewStage'); showEl('cropStage'); setStep(2); }
function changePhoto(){ hideEl('cropStage'); uploadZone.style.display=''; document.getElementById('fileInput').value=''; setStep(1); }
function startOver() { srcImg=null; hideEl('cropStage'); hideEl('previewStage'); uploadZone.style.display=''; document.getElementById('fileInput').value=''; setStep(1); }
function showEl(id)  { document.getElementById(id).classList.add('visible'); }
function hideEl(id)  { document.getElementById(id).classList.remove('visible'); }
function setStep(n)  { [1,2,3].forEach((_, i) => { document.getElementById('d'+(i+1)).classList.toggle('on', i+1 <= n); }); }

// ── Hashtag copy ────────────────────────────────────────────────────────
function copyTag(el) {
  navigator.clipboard.writeText(el.textContent).then(() => {
    const n = document.getElementById('copyNotice');
    n.innerHTML = '<span>' + el.textContent + '</span> কপি হয়েছে ✓';
    setTimeout(() => { n.innerHTML = 'হ্যাশট্যাগে ক্লিক করলে <span>কপি</span> হয়ে যাবে'; }, 2000);
  });
}
